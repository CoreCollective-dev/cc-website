---
import { Image } from 'astro:assets';
import membersTitle from '../assets/members.svg';
import { getEntry } from 'astro:content';
import PageTitle from './PageTitle.astro';

const companyLogos = await getEntry('logos', 'company');
const images = companyLogos?.data;
---

<div class="flex w-full flex-col items-center gap-24 py-12">
  <PageTitle path={membersTitle} />

  <ul
    class="flex w-full max-w-2/3 flex-wrap items-center justify-center gap-8 px-4 pt-8 sm:gap-10 md:gap-12"
  >
    {
      images?.map((img: any) => (
        <li class="flex h-16 w-28 shrink-0 items-center justify-center sm:h-20 sm:w-32 md:h-32 md:w-64">
          <Image
            src={img.src}
            alt={img.alt}
            class="h-full w-full object-contain"
            inferSize={true}
          />
        </li>
      ))
    }
  </ul>
</div>
